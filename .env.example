# ===== 鉴权（必填，否则拒绝启动） =====
# 登录页的用户名与密码，请使用强口令
AUTH_USERNAME=admin
AUTH_PASSWORD=change-me
# 可选：登录会话签名密钥；不设置时默认复用 AUTH_PASSWORD
AUTH_SESSION_SECRET=
# 可选：登录会话有效期（秒），默认 86400
AUTH_SESSION_TTL_SECONDS=86400
# 可选：HTTPS 部署时建议设置为 true，让浏览器仅通过 HTTPS 发送登录 cookie
AUTH_COOKIE_SECURE=false

# ===== 服务监听（可选） =====
# 监听端口，默认 9000
PORT=9000
# 监听地址，默认 0.0.0.0（建议生产环境配合反向代理，仅监听 127.0.0.1）
HOST=0.0.0.0

# ===== 巡检策略（可选） =====
# 定时巡检 cron 表达式，默认每天 0 点
CHECK_CRON=0 0 * * *
# 证书剩余天数低于此值时触发短信告警，默认 3
WARN_DAYS=3
# 单次 TLS 请求超时（毫秒），默认 5000
REQUEST_TIMEOUT=5000
# 单个域名最大重试次数，默认 5
MAX_RETRIES=5

# ===== 短信服务（可选，不配置则仅记录日志、不发短信） =====
SMS_BASE_URL=https://example.com
SMS_TEMPLATE_ID=xxx
SMS_APPID=xxx
SMS_APPKEY=xxx
SMS_TYPE=submail
SMS_AUTH=xxx
# 短信接口超时（毫秒），默认 10000
SMS_TIMEOUT=10000
